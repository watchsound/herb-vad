# Jupyter
.ipynb_checkpoints/

# DVC / data directories — ignore all contents but keep .gitkeep sentinels
# so the empty directory structure is tracked. Order matters: re-include
# subdirectories themselves so git descends into them, then re-include only
# the .gitkeep files inside.
/data/raw/**
/data/interim/**
/data/processed/**
/data/external/**
!/data/raw/*/
!**/.gitkeep
*.dvc
.dvc/cache
.dvc/tmp
.dvc/plots

# Logs / artifacts
*.log
logs/
artifacts/
runs/
outputs/

# Secrets
.env
.env.*
!.env.example

# Claude Code working files
.claude/
PHARMACOPOEIA-1a.pdf
PHARMACOPOEIA-1b.pdf
